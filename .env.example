# ==========================================
# Smart Heating Dashboard - Environment Variables
# ==========================================

# OpenWeatherMap API (Get from: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweathermap_api_key

# Shelly Cloud API (Get from Shelly cloud device settings)
SHELLY_API_URL=https://shelly-13.shelly.cloud
SHELLY_AUTH_KEY=your_shelly_auth_key

# OpenAI API (Get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key