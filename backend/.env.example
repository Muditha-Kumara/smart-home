# Database
DATABASE_URL="postgresql://postgres:postgres@db:5432/smart_heating?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# OpenWeatherMap API
OPENWEATHER_API_KEY="your_openweathermap_api_key"

# Nord Pool Electricity Prices (optional - can use free APIs)
NORDPOOL_API_URL="https://dashboard.elering.ee/api"

# Shelly Cloud API
SHELLY_API_URL="https://shelly-XX.shelly.cloud"
SHELLY_AUTH_KEY="your_shelly_auth_key"

# OpenAI API for LLM optimization
OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-4o-mini"

# Server
PORT=5000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:5173"