# ==========================================
# DEPENDENCIES
# ==========================================
# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# ENVIRONMENT VARIABLES (CRITICAL FOR SECURITY)
# ==========================================
# Protects your Shelly Cloud API keys, Nord Pool API keys, and JWT secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ==========================================
# BUILD OUTPUTS
# ==========================================
# React (Create React App / Vite)
build/
dist/
.vite/

# ==========================================
# LOGS & CACHES
# ==========================================
logs/
*.log
lerna-debug.log*
.pnpm-store/
.eslintcache

# ==========================================
# TESTING & COVERAGE
# ==========================================
coverage/
.nyc_output/

# ==========================================
# IDE & EDITOR FILES
# ==========================================
# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs (WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
*~
.DS_Store

# ==========================================
# OS GENERATED FILES
# ==========================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ==========================================
# CONTINUE.DEV & AI TOOLS
# ==========================================
# If Continue.dev generates local cache or context files
.continue/
*.continue.json

# ==========================================
# DESIGN & DOCUMENTATION EXPORTS (OPTIONAL)
# ==========================================
# If you export Penpot designs or PDF reports locally
*.pdf
*.sketch
*.fig